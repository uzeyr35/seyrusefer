rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar: herkes okuyabilir, sadece kendi uid'i yazabilir
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // İlanlar: herkes okuyabilir, giriş yapan ekleyebilir, sadece sahibi güncelleyebilir
    match /ilans/{ilanId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.owner;
    }

    // Konuşmalar: sadece katılımcılar erişebilir
    match /convs/{convId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Mesajlar
      match /messages/{msgId} {
        allow read, create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/convs/$(convId)).data.participants;
      }
    }
  }
}
